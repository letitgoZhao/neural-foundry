# Qwen3-1.7B vLLM deployment defaults.
# Copy this file to .env or export values in your shell when you need overrides.

MODEL_ID=Qwen/Qwen3-1.7B
SERVED_MODEL_NAME=Qwen/Qwen3-1.7B

HOST=0.0.0.0
PORT=8000

# Start conservative. Qwen3-1.7B supports 32768 context, but 8192 is easier
# for first deployment and leaves enough headroom for reasoning output.
MAX_MODEL_LEN=8192
GPU_MEMORY_UTILIZATION=0.75

# Keep model cache outside the Git repository.
HF_HOME=/data/neural-foundry/hf-cache

# Set to true if Hugging Face is slow or unavailable from the cloud host.
VLLM_USE_MODELSCOPE=false

# Qwen3 thinking output parsing. Requires a vLLM version with the qwen3 parser.
ENABLE_REASONING=1
REASONING_PARSER=qwen3
